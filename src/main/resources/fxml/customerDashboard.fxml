<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane fx:id="rootPane" styleClass="customer-root" stylesheets="@../css/customerDashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.CustomerPortalController">

    <!-- LEFT SIDEBAR -->
    <left>
        <StackPane styleClass="sidebar">

            <!-- Main nav content pinned to top -->
            <VBox spacing="22" style="-fx-padding: 32 18 24 18;" StackPane.alignment="TOP_LEFT">
                <HBox alignment="TOP_LEFT" spacing="12" styleClass="sidebar-brand-row">
                    <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                        <HBox.margin>
                            <Insets left="4.0" top="-8.0" />
                        </HBox.margin>
                        <Image url="@/images/VALET_APP_RAM_LOGO_OFFICIAL.png" />
                    </ImageView>
                    <VBox spacing="2">
                        <Label styleClass="sidebar-brand" text="FSC VALET" />
                        <Label styleClass="sidebar-subtitle" text="RAM Portal" />
                    </VBox>
                </HBox>

                <VBox spacing="10">
                    <Button fx:id="sideCheckInBtn" onAction="#showCheckIn" styleClass="sidebar-button, sidebar-button-active" text="Check In" />
                    <Button fx:id="sideTicketsBtn" onAction="#showMyTickets" styleClass="sidebar-button" text="My Ticket" />
                    <Button fx:id="sidePickupBtn" onAction="#showRequestPickup" styleClass="sidebar-button" text="Request Pickup" />
                </VBox>
            </VBox>

            <!-- Profile pinned to bottom -->
            <VBox style="-fx-padding: 0 18 45 18;" StackPane.alignment="BOTTOM_LEFT" pickOnBounds="false">
                <Button onAction="#handleProfile" styleClass="sidebar-button" text="Profile">
               <VBox.margin>
                  <Insets top="760.0" />
               </VBox.margin></Button>
            </VBox>
        </StackPane>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <StackPane styleClass="customer-scroll">
            <VBox spacing="0" styleClass="customer-content">

                <!-- WELCOME -->
                <VBox alignment="CENTER" minHeight="40" style="-fx-padding: 4 0 8 0; -fx-background-color: transparent;">
                    <Label fx:id="welcomeLabel" styleClass="welcome-banner" text="Welcome, Adrianna">
                  <VBox.margin>
                     <Insets left="980.0" top="-100.0" />
                  </VBox.margin>
                  <padding>
                     <Insets left="100.0" right="10.0" />
                  </padding></Label>
                </VBox>

                <!-- NAV PILLS -->
                <HBox alignment="CENTER" spacing="12" styleClass="nav-pill-bar">
                    <Button fx:id="navCheckInBtn" onAction="#showCheckIn" styleClass="nav-pill, nav-pill-active" text="🚗  Check In" />
                    <Button fx:id="navTicketsBtn" onAction="#showMyTickets" styleClass="nav-pill" text="🔍  My Ticket" />
                    <Button fx:id="navPickupBtn" onAction="#showRequestPickup" styleClass="nav-pill" text="↪  Request Pickup" />
               <VBox.margin>
                  <Insets top="-55.0" />
               </VBox.margin>
               <opaqueInsets>
                  <Insets />
               </opaqueInsets>
                </HBox>

                <!-- SECTIONS -->
                <VBox alignment="TOP_CENTER" style="-fx-padding: 28 32 32 32;">

                    <!-- CHECK IN SECTION -->
                    <VBox fx:id="checkInSection" maxWidth="560" styleClass="form-card">

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 16px;" text="🚗" />
                            <Label styleClass="card-title" text="Vehicle Check-In">
                        <HBox.margin>
                           <Insets left="-25.0" />
                        </HBox.margin></Label>
                        </HBox>
                        <Label fx:id="availableSpotsLabel" styleClass="card-subtitle" text="Please provide your vehicle details. Available spots: —" />
                        <Region styleClass="card-divider" />

                        <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 8 0 4 0;">
                            <Label style="-fx-font-size: 13px;" text="👤" />
                            <Label styleClass="sub-heading" text="Your Information">
                        <HBox.margin>
                           <Insets left="-20.0" />
                        </HBox.margin></Label>
                        </HBox>

                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Full Name *" />
                                <TextField promptText="John Doe" styleClass="field-input" />
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Phone Number *" />
                                <TextField promptText="(555) 123-4567" styleClass="field-input" />
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="6" style="-fx-padding: 8 0 4 0;">
                            <Label style="-fx-font-size: 13px;" text="🚗" />
                            <Label styleClass="sub-heading" text="Vehicle Details">
                        <HBox.margin>
                           <Insets left="-20.0" />
                        </HBox.margin></Label>
                        </HBox>

                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Make *" />
                                <TextField fx:id="ciMakeField" promptText="Toyota" styleClass="field-input" />
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Model *" />
                                <TextField fx:id="ciModelField" promptText="Camry" styleClass="field-input" />
                            </VBox>
                        </HBox>

                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Year *" />
                                <TextField fx:id="ciYearField" promptText="2022" styleClass="field-input" />
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Color" />
                                <TextField fx:id="ciColorField" promptText="Blue" styleClass="field-input" />
                            </VBox>
                        </HBox>

                        <HBox spacing="16">
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="License Plate" />
                                <TextField fx:id="ciPlateField" promptText="ABC-1234" styleClass="field-input" />
                            </VBox>
                            <VBox spacing="6" HBox.hgrow="ALWAYS">
                                <Label styleClass="field-label" text="Preferred Parking Area" />
                                <TextField fx:id="ciParkingSpaceField" promptText="e.g., Main Lot, Covered, Near Exit" styleClass="field-input" />
                            </VBox>
                        </HBox>

                        <VBox spacing="6" style="-fx-padding: 4 0 0 0;">
                            <Label styleClass="field-label" text="Special Instructions (Optional)" />
                            <TextArea prefHeight="90" promptText="Any special handling instructions..." styleClass="field-input" wrapText="true" />
                        </VBox>

                        <Label fx:id="checkInStatusLabel" style="-fx-text-fill: red;" styleClass="field-label" text="" />
                        <Button maxWidth="Infinity" onAction="#handleCheckIn" style="-fx-padding: 14 0 14 0;" styleClass="checkin-btn" text="Complete Check-In" />
                  <VBox.margin>
                     <Insets top="-10.0" />
                  </VBox.margin>
                    </VBox>

                    <!-- MY TICKETS SECTION -->
                    <VBox fx:id="myTicketsSection" managed="false" maxWidth="560" styleClass="form-card" visible="false">

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 16px;" text="🎟️" />
                            <Label styleClass="card-title" text="My Tickets" />
                        </HBox>
                        <Region styleClass="card-divider" />

                        <VBox fx:id="ticketsEmptyState">
                            <Label styleClass="card-subtitle" text="You have no active tickets." />
                        </VBox>

                        <VBox fx:id="ticketListContainer" managed="false" spacing="10" visible="false" />
                    </VBox>

                    <!-- REQUEST PICKUP SECTION -->
                    <VBox fx:id="requestPickupSection" managed="false" maxWidth="560" styleClass="form-card" visible="false">

                        <HBox alignment="CENTER_LEFT" spacing="8">
                            <Label style="-fx-font-size: 16px;" text="↪" />
                            <Label styleClass="card-title" text="Request Pickup" />
                        </HBox>
                        <Region styleClass="card-divider" />

                        <Label styleClass="field-label" text="Select your vehicle:" />
                        <ComboBox fx:id="carSelectCombo" maxWidth="Infinity" />
                        <Label fx:id="pickupStatusLabel" style="-fx-text-fill: red;" styleClass="field-label" text="" />
                        <Button maxWidth="Infinity" onAction="#handleRequestPickup" style="-fx-padding: 14 0 14 0;" styleClass="checkin-btn" text="Request Pickup" />
                    </VBox>

                </VBox>
            </VBox>
        </StackPane>
    </center>

</BorderPane>
