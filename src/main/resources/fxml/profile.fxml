<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/17.0.12"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="client.controller.ProfileController"
            stylesheets="@../css/profile.css"
            styleClass="root">

    <top>
        <HBox styleClass="mr-header">
            <Button text="← Back" onAction="#handleBack" styleClass="back-btn"/>
            <Label text=" FSC VALET - PROFILE" styleClass="mr-title"/>
        </HBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" fitToHeight="true" styleClass="mr-scroll" hbarPolicy="NEVER">
            <StackPane>
                <padding>
                    <Insets top="40" right="24" bottom="40" left="24"/>
                </padding>

                <VBox spacing="20" alignment="TOP_CENTER">

                    <!-- ── ACCOUNT INFO + EDIT PROFILE ── -->
                    <VBox styleClass="form-card">
                        <padding>
                            <Insets top="36" right="40" bottom="36" left="40"/>
                        </padding>

                        <Label text="Account Info" styleClass="section-title"/>
                        <Region styleClass="section-divider" maxWidth="Infinity"/>

                        <VBox spacing="4">
                            <Label text="FULL NAME" styleClass="field-label"/>
                            <Label fx:id="fullNameLabel" text="—" styleClass="info-text"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="EMAIL" styleClass="field-label"/>
                            <Label fx:id="emailLabel" text="—" styleClass="info-text"/>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="ROLE" styleClass="field-label"/>
                            <Label fx:id="roleLabel" text="—" styleClass="info-text"/>
                        </VBox>

                        <Region styleClass="section-divider" maxWidth="Infinity"/>

                        <Label text="Edit Profile" styleClass="section-title"/>

                        <VBox spacing="4">
                            <Label text="FULL NAME" styleClass="field-label"/>
                            <HBox styleClass="input-box">
                                <TextField fx:id="fullNameField" promptText="Full name"
                                           styleClass="input-field" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="PHONE NUMBER (optional)" styleClass="field-label"/>
                            <HBox styleClass="input-box">
                                <TextField fx:id="phoneField" promptText="e.g. 555-867-5309"
                                           styleClass="input-field" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <Label fx:id="profileStatusLabel" text="" styleClass="status-label"/>
                        <Button text="Save Changes" onAction="#handleSaveProfile"
                                styleClass="submit-btn" maxWidth="Infinity"/>
                    </VBox>

                    <!-- ── CHANGE PASSWORD ── -->
                    <VBox styleClass="form-card">
                        <padding>
                            <Insets top="36" right="40" bottom="36" left="40"/>
                        </padding>

                        <Label text="Change Password" styleClass="section-title"/>
                        <Region styleClass="section-divider" maxWidth="Infinity"/>

                        <VBox spacing="4">
                            <Label text="NEW PASSWORD" styleClass="field-label"/>
                            <HBox styleClass="input-box">
                                <PasswordField fx:id="newPasswordField" promptText="At least 6 characters"
                                               styleClass="input-field" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <VBox spacing="4">
                            <Label text="CONFIRM NEW PASSWORD" styleClass="field-label"/>
                            <HBox styleClass="input-box">
                                <PasswordField fx:id="confirmPasswordField" promptText="Re-enter password"
                                               styleClass="input-field" HBox.hgrow="ALWAYS"/>
                            </HBox>
                        </VBox>

                        <Label fx:id="passwordStatusLabel" text="" styleClass="status-label"/>
                        <Button text="Update Password" onAction="#handleChangePassword"
                                styleClass="submit-btn" maxWidth="Infinity"/>
                    </VBox>

                    <!-- ── LOG OUT ── -->
                    <VBox styleClass="form-card">
                        <padding>
                            <Insets top="24" right="40" bottom="24" left="40"/>
                        </padding>

                        <Button text="Log Out" onAction="#handleLogOut"
                                styleClass="logout-btn" maxWidth="Infinity"/>
                    </VBox>

                </VBox>
            </StackPane>
        </ScrollPane>
    </center>
</BorderPane>
