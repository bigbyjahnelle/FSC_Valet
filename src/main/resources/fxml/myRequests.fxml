<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="root" stylesheets="@../css/my_requests.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.MyRequestsController">

    <top>
        <HBox styleClass="mr-header">
            <Button onAction="#handleBack" styleClass="back-btn" text="← Back" />


            <Label styleClass="mr-title" text=" FSC VALET - REQUESTS" />

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#handleMakeRequest" prefHeight="30.0" prefWidth="90.0" styleClass="submit-btn" text="Help">
            <HBox.margin>
               <Insets right="-4.0" />
            </HBox.margin></Button>
        </HBox>
    </top>

    <center>
        <ScrollPane fx:id="pageScroll" fitToWidth="true" styleClass="mr-scroll">
            <content>
                <VBox alignment="TOP_CENTER" spacing="20" style="-fx-padding: 28;">

                    <VBox styleClass="form-card">
                        <padding>
                            <Insets bottom="24" left="24" right="24" top="24" />
                        </padding>

                        <Label styleClass="section-title" text="Request History" />
                        <Region styleClass="section-divider" />

                        <Label styleClass="info-text" text="Track all your valet tickets and check the current status of each request." wrapText="true" />

                        <VBox fx:id="emptyState" alignment="CENTER" spacing="14" styleClass="empty-state-box">
                            <ImageView fitHeight="95.0" fitWidth="95.0" preserveRatio="true">
                                <Image url="@/images/VALET_APP_RAM_LOGO_OFFICIAL.png" />
                            </ImageView>

                            <Label styleClass="empty-state-title" text="No requests found" />

                            <Label styleClass="empty-state-text" text="You have not submitted any valet requests yet. Once you do, your tickets will appear here." wrapText="true" />

                            <Button onAction="#handleMakeRequest" prefWidth="220" styleClass="submit-btn" text="Make a Request" />
                        </VBox>

                        <VBox fx:id="ticketList" managed="false" spacing="14" visible="false">
                            <padding>
                                <Insets bottom="4" left="2" right="2" top="4" />
                            </padding>
                        </VBox>
                    </VBox>

                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
