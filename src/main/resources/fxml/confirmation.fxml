<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="confirmation-root" stylesheets="@../css/confirmation.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.PickupConfirmationController">

    <top>
        <HBox alignment="CENTER_LEFT" spacing="14" styleClass="top-bar">

            <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                <HBox.margin>
                    <Insets left="-6.0" right="-2.0" top="-2.0" />
                </HBox.margin>
                <Image url="@/images/VALET_APP_RAM_LOGO_OFFICIAL.png" />
            </ImageView>

            <VBox spacing="2">
                <Label styleClass="brand-title" text="FSC VALET">
               <VBox.margin>
                  <Insets />
               </VBox.margin></Label>
                <Label styleClass="brand-subtitle" text="Pickup Confirmation" />
            </VBox>

            <Region HBox.hgrow="ALWAYS" />

            <Button onAction="#handleBackToDashboard" styleClass="top-button" text="Back to Dashboard" />
        </HBox>
    </top>

    <center>
        <StackPane styleClass="center-area">
            <VBox alignment="CENTER" spacing="22" styleClass="confirmation-wrapper">

                <VBox alignment="CENTER" spacing="22" styleClass="confirmation-card">
                    <Label styleClass="confirmation-title" text="Request&#10;Confirmed!" />

                    <Label styleClass="confirmation-check" text="✓" />

                    <VBox alignment="CENTER" spacing="8">
                        <Label fx:id="dateLabel" styleClass="detail-text" text="Date: May 2, 2026" />

                        <Label fx:id="reservationNumberLabel" styleClass="detail-text" text="Reservation Number: 2340" />

                        <Label fx:id="valetAttendantLabel" styleClass="detail-text" text="Valet Attendant: Jimmy Dean" />

                        <Label fx:id="ramIdLabel" styleClass="detail-text" text="RAM ID: R002" />
                    </VBox>

                    <Label styleClass="sub-message" text="Your pickup request has been successfully submitted." wrapText="true" />
                </VBox>

                <HBox alignment="CENTER" spacing="14">
                    <Button fx:id="cancelRequestButton" onAction="#handleCancelRequest" styleClass="cancel-button" text="Cancel Request" />

                    <Button fx:id="doneButton" onAction="#handleBackToDashboard" styleClass="done-button" text="Done" />
                </HBox>

            </VBox>
        </StackPane>
    </center>
</BorderPane>
