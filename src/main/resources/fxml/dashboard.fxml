<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>

<BorderPane styleClass="dashboard-root" stylesheets="@../css/dashboard.css" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="client.controller.DashboardController">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox spacing="22" styleClass="sidebar">
            <HBox alignment="TOP_LEFT" spacing="12" styleClass="sidebar-brand-row">

                <ImageView fitHeight="60" fitWidth="60" preserveRatio="true">
                    <HBox.margin>
                        <Insets left="4.0" top="-8.0" />
                    </HBox.margin>
                    <Image url="@/images/VALET_APP_RAM_LOGO_OFFICIAL.png" />
                </ImageView>

                <VBox spacing="2">
                    <Label styleClass="sidebar-brand" text="FSC VALET" />
                    <Label styleClass="sidebar-subtitle" text="RAM Portal" />
                </VBox>
            </HBox>

            <VBox spacing="10">
                <Button fx:id="navCheckInButton" onAction="#handleCheckIn" styleClass="sidebar-button" text="Make a Request" />

                <Button fx:id="navActiveVehiclesButton" onAction="#handleActiveVehicles" styleClass="sidebar-button" text="My Requests" />

                <Button onAction="#handleProfile" styleClass="sidebar-button" text="Profile" />
            </VBox>

            <Region VBox.vgrow="ALWAYS" />
        </VBox>
    </left>

    <!-- MAIN CONTENT -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="dashboard-scroll">
            <content>
                <VBox spacing="20" styleClass="dashboard-content">

                    <!-- TOP BAR -->
                    <HBox alignment="CENTER_RIGHT">
                        <Label fx:id="userNameLabel" styleClass="top-brand" text="" />
                    </HBox>

                    <!-- 4 STAT CARDS -->
                    <HBox spacing="16">
                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label styleClass="stat-card-label" text="Active Vehicles" />
                                    <Label fx:id="activeVehiclesLabel" styleClass="stat-card-value" text="0" />
                                </VBox>
                                <StackPane styleClass="stat-icon stat-icon-blue">
                                    <Label style="-fx-font-size: 22px;" text="🚗" />
                                </StackPane>
                            </HBox>
                        </VBox>

                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label styleClass="stat-card-label" text="Available Spots" />
                                    <Label fx:id="availableSpotsLabel" styleClass="stat-card-value" text="50" />
                                </VBox>
                                <StackPane styleClass="stat-icon stat-icon-green">
                                    <Label styleClass="stat-icon-letter stat-icon-letter-green" text="P" />
                                </StackPane>
                            </HBox>
                        </VBox>

                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label styleClass="stat-card-label" text="Total Capacity" />
                                    <Label fx:id="totalCapacityLabel" styleClass="stat-card-value" text="50" />
                                </VBox>
                                <StackPane styleClass="stat-icon stat-icon-purple">
                                    <Label styleClass="stat-icon-letter stat-icon-letter-purple" text="↗" />
                                </StackPane>
                            </HBox>
                        </VBox>

                        <VBox styleClass="stat-card" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT">
                                <VBox spacing="6" HBox.hgrow="ALWAYS">
                                    <Label styleClass="stat-card-label" text="Today's Check-ins" />
                                    <Label fx:id="todayCheckinsLabel" styleClass="stat-card-value" text="0" />
                                </VBox>
                                <StackPane styleClass="stat-icon stat-icon-orange">
                                    <Label style="-fx-font-size: 22px;" text="🕐" />
                                </StackPane>
                            </HBox>
                        </VBox>
                    </HBox>

                    <!-- PARKING STATUS -->
                    <VBox spacing="12" styleClass="section-panel">
                        <Label styleClass="panel-title" text="Parking Status" />

                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="stat-card-label" text="Occupancy Rate" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="occupancyPercentLabel" styleClass="occupancy-percent" text="0%" />
                        </HBox>

                        <ProgressBar fx:id="occupancyBar" maxWidth="Infinity" progress="0" styleClass="dashboard-progress-bar" />

                        <HBox>
                            <Label fx:id="parkedCountLabel" styleClass="stat-card-label" text="0 Parked" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Label fx:id="availableCountLabel" styleClass="stat-card-label" text="50 Available" />
                        </HBox>
                    </VBox>

                    <!-- RECENT CHECK-INS -->
                    <VBox spacing="14" styleClass="section-panel">
                        <HBox alignment="CENTER_LEFT">
                            <Label styleClass="panel-title" text="Recent Check-ins" />
                            <Region HBox.hgrow="ALWAYS" />
                            <Button fx:id="viewAllButton" onAction="#handleViewAll" styleClass="outline-button" text="View All" />
                        </HBox>

                        <VBox fx:id="emptyState" alignment="CENTER" spacing="12" styleClass="empty-state-box">
                            <Label styleClass="empty-car-icon" text="🚗" />
                            <Label styleClass="empty-state-title" text="No vehicles parked yet" />
                            <Button fx:id="checkInFirstButton" onAction="#handleCheckIn" styleClass="primary-button" text="Check In First Vehicle" />
                        </VBox>

                        <VBox fx:id="vehicleListContainer" managed="false" spacing="10" visible="false" />
                    </VBox>

                    <!-- BOTTOM ACTION CARDS -->
                    <HBox spacing="16">
                        <VBox onMouseClicked="#handleCheckIn" styleClass="action-card-dashed" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <StackPane styleClass="action-icon action-icon-blue">
                                    <Label styleClass="action-icon-plus" text="+" />
                                </StackPane>
                                <VBox spacing="4">
                                    <Label styleClass="action-title" text="Check In Vehicle" />
                                    <Label styleClass="action-subtitle" text="Add new vehicle to parking" />
                                </VBox>
                            </HBox>
                        </VBox>

                        <VBox onMouseClicked="#handleActiveVehicles" styleClass="action-card-dashed" HBox.hgrow="ALWAYS">
                            <HBox alignment="CENTER_LEFT" spacing="16">
                                <StackPane styleClass="action-icon action-icon-green">
                                    <Label styleClass="action-icon-menu" text="≡" />
                                </StackPane>
                                <VBox spacing="4">
                                    <Label styleClass="action-title" text="View Active Vehicles" />
                                    <Label styleClass="action-subtitle" text="Manage parked vehicles" />
                                </VBox>
                            </HBox>
                        </VBox>
                    </HBox>

                    <padding>
                        <Insets bottom="24" left="24" right="24" top="24" />
                    </padding>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
